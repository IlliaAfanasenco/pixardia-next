generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum ServiceCode {
  BUSINESS_WEBSITE
  LANDING_PAGE
  WEB_APPLICATION
  ECOMMERCE
  WEBSITE_REDESIGN
  UI_UX_DESIGN
  AI_AUTOMATION
  MAINTENANCE_SUPPORT
}

enum LeadStatus {
  NEW
  IN_PROCESS
  WON
  LOST
}

model Lead {
  id       String  @id @default(cuid())
  name     String
  email    String
  phone    String?
  message  String
  language String  @default("en")

  serviceCode ServiceCode
  serviceSlug String

  sourcePage String?
  status     LeadStatus @default(NEW)

  privacyAcceptedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([serviceCode])
  @@index([status])
  @@index([createdAt])
}
